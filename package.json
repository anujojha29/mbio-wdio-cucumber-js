{
  "name": "mbio-wdio-cucumber-js-framework",
  "version": "1.0.0",
  "private": true,
  "description": "WebdriverIO + Cucumber + JavaScript automation framework for mb.io public web flows",
  "scripts": {
    "test": "wdio run ./wdio.conf.js",
    "test:smoke": "set TAGS=@smoke && wdio run ./wdio.conf.js",
    "test:regression": "set TAGS=@regression && wdio run ./wdio.conf.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@wdio/cli": "^9.19.2",
    "@wdio/cucumber-framework": "^9.19.2",
    "@wdio/junit-reporter": "^9.19.2",
    "@wdio/local-runner": "^9.19.2",
    "@wdio/spec-reporter": "^9.19.2",
    "@cucumber/cucumber": "^10.9.0",
    "chromedriver": "^148.0.0",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "wdio-chromedriver-service": "^8.1.1",
    "@wdio/allure-reporter": "^9.19.2",
    "allure-commandline": "^2.34.1"
  }
}
